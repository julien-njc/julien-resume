{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resume Editor",
  "version": "0.1.0",
  "identifier": "com.julienpireaud.resumeeditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Resume Editor",
        "width": 1440,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../Dockerfile": "docker/Dockerfile",
      "../../scripts/build-resume.sh": "docker/scripts/build-resume.sh",
      "../../scripts/resume_model.py": "docker/scripts/resume_model.py",
      "../../scripts/render_resume.py": "docker/scripts/render_resume.py",
      "../../scripts/build_ats_docx.py": "docker/scripts/build_ats_docx.py",
      "../../resume-ats.css": "docker/resume-ats.css",
      "../../resume-stylish.css": "docker/resume-stylish.css"
    }
  }
}
