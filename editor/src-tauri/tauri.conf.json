{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resume Editor",
  "version": "0.1.0",
  "identifier": "com.julien.resumeeditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Resume Editor",
        "width": 1440,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
